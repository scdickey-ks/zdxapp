# Copy to `.env` and fill in. Real credentials belong ONLY in `.env` (gitignored).

# Runtime target (test-first model)
ZDX_ENV=test

# Tenant context (from case 06193646 context)
ZDX_CLOUD=zscalerthree.net

# OneAPI (optional — only if using zslogin OAuth + api.zsapi.net; see scripts/pilot/zdx_api_smoke.py)
# ZSCALER_VANITY_DOMAIN=
# ZSCALER_CLOUD=

# Base URLs (set when support confirms exact FQDNs)
ZDX_BASE_URL_TEST=
ZDX_BASE_URL_PROD=

# Client credentials (secret auth model)
ZDX_CLIENT_ID_TEST=
ZDX_CLIENT_SECRET_TEST=
ZDX_CLIENT_ID_PROD=
ZDX_CLIENT_SECRET_PROD=

# Token endpoint/path (if distinct from base URL)
ZDX_TOKEN_ENDPOINT_TEST=
ZDX_TOKEN_ENDPOINT_PROD=

# Backward-compatible key fields (if used by legacy scripts)
# ZDX_KEY_ID=
# ZDX_KEY_SECRET=
# ZDX_BASE_URL=

# Phase 1 — alerts via workflow webhook
# ALERT_WEBHOOK_URL=
# ALERT_WEBHOOK_HEADERS_JSON=

# Phase 2 — ServiceNow (see docs/requirements.md integrations)
# SERVICENOW_INSTANCE=
# SERVICENOW_CLIENT_ID=
# SERVICENOW_CLIENT_SECRET=
